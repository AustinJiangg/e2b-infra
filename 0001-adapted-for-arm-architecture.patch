diff --git a/helm/templates/api.yaml b/helm/templates/api.yaml
new file mode 100644
index 0000000..06f7f57
--- /dev/null
+++ b/helm/templates/api.yaml
@@ -0,0 +1,195 @@
+apiVersion: apps/v1
+kind: Deployment
+metadata:
+  name: api
+  namespace: e2b
+  labels:
+    app: api
+spec:
+  replicas: 1
+  selector:
+    matchLabels:
+      app: api
+  template:
+    metadata:
+      labels:
+        app: api
+    spec:
+      serviceAccountName: e2b-orchestrator
+      affinity:
+        nodeAffinity:
+          requiredDuringSchedulingIgnoredDuringExecution:
+            nodeSelectorTerms:
+            - matchExpressions:
+              - key: node-role.kubernetes.io/{{ .Values.api.pool }}
+                operator: Exists
+      hostNetwork: true
+      dnsPolicy: ClusterFirstWithHostNet
+      initContainers:
+      - name: db-migrator
+        image: "{{ .Values.registry }}/{{ .Values.image.migrator }}"
+        imagePullPolicy: {{ .Values.pullPolicy }}
+        env:
+        - name: NODE_ID
+          valueFrom: { fieldRef: { fieldPath: spec.nodeName } }
+        - name: ORCHESTRATOR_TYPE
+          value: "{{ .Values.orchestratorType }}"
+        - name: ORCHESTRATOR_PORT
+          value: "{{ .Values.orchestratorPort }}"
+        - name: TEMPLATE_MANAGER_HOST
+          value: "{{ .Values.templateManagerHost }}"
+        - name: POSTGRES_CONNECTION_STRING
+          value: "{{ .Values.postgresConnectionString }}"
+        - name: SUPABASE_JWT_SECRETS
+          value: "{{ .Values.supabaseJwtSecrets }}"
+        - name: CLICKHOUSE_CONNECTION_STRING
+          value: "clickhouse://{{ .Values.clickhouseUsername }}:{{ .Values.clickhousePassword }}@127.0.0.1:{{ .Values.clickhouseServerPort }}/{{ .Values.clickhouseDatabase }}"
+        - name: ENVIRONMENT
+          value: "dev"
+        - name: POSTHOG_API_KEY
+          value: "{{ .Values.posthogApiKey }}"
+        - name: ANALYTICS_COLLECTOR_HOST
+          value: "{{ .Values.analyticsCollectorHost }}"
+        - name: ANALYTICS_COLLECTOR_API_TOKEN
+          value: "{{ .Values.analyticsCollectorApiToken }}"
+        - name: OTEL_TRACING_PRINT
+          value: "{{ .Values.otelTracingPrint }}"
+        - name: LOGS_COLLECTOR_ADDRESS
+          value: "{{ .Values.logsCollectorAddress }}"
+        - name: OTEL_COLLECTOR_GRPC_ENDPOINT
+          value: "{{ .Values.otelCollectorGrpcEndpoint }}"
+        - name: ADMIN_TOKEN
+          value: "{{ .Values.apiAdminToken }}"
+        - name: REDIS_URL
+          value: "{{ .Values.redisUrl }}:{{ .Values.redisPort | int }}"
+        - name: REDIS_CLUSTER_URL
+          value: "{{ .Values.redisClusterUrl }}"
+        - name: DNS_PORT
+          value: "{{ .Values.dnsPort }}"
+        - name: SANDBOX_ACCESS_TOKEN_HASH_SEED
+          value: "{{ .Values.sandboxAccessTokenHashSeed }}"
+        - name: LOCAL_CLUSTER_ENDPOINT
+          value: "{{ .Values.localClusterEndpoint }}"
+        - name: LOCAL_CLUSTER_TOKEN
+          value: "{{ .Values.edgeApiSecret }}"
+        - name: TEMPLATE_BUCKET_NAME
+          value: "{{ .Values.templateBucketName }}"
+        resources:
+          requests:
+            cpu: 250m
+            memory: 128Mi
+          limits:
+            cpu: 250m
+            memory: 128Mi
+      - name: wait-redis
+        image: busybox:latest
+        imagePullPolicy: IfNotPresent
+        command:
+        - /bin/sh
+        - -c
+        - |
+          until nc -z redis.e2b.svc.cluster.local {{ .Values.redisPort | int }}; do
+            echo waiting for redis...
+            sleep 1
+          done
+      containers:
+      - name: api
+        image: "{{ .Values.registry }}/{{ .Values.image.api }}"
+        imagePullPolicy: {{ .Values.pullPolicy }}
+        args: ["--port", "{{ .Values.apiPort | int }}"]
+        ports:
+        - containerPort: {{ .Values.apiPort | int }}
+          name: api
+        - containerPort: {{ .Values.dnsPort | int }}
+          name: dns
+          protocol: UDP
+        env:
+        - name: NODE_ID
+          valueFrom: { fieldRef: { fieldPath: spec.nodeName } }
+        - name: ORCHESTRATOR_TYPE
+          value: "{{ .Values.orchestratorType }}"
+        - name: ORCHESTRATOR_PORT
+          value: "{{ .Values.orchestratorPort }}"
+        - name: API_GRPC_PORT
+          value: "{{ .Values.apiGrpcPort }}"
+        - name: POSTGRES_CONNECTION_STRING
+          value: "{{ .Values.postgresConnectionString }}"
+        - name: SUPABASE_JWT_SECRETS
+          value: "{{ .Values.supabaseJwtSecrets }}"
+        - name: CLICKHOUSE_CONNECTION_STRING
+          value: "clickhouse://{{ .Values.clickhouseUsername }}:{{ .Values.clickhousePassword }}@127.0.0.1:{{ .Values.clickhouseServerPort }}/{{ .Values.clickhouseDatabase }}"
+        - name: ENVIRONMENT
+          value: "dev"
+        - name: POSTHOG_API_KEY
+          value: "{{ .Values.posthogApiKey }}"
+        - name: ANALYTICS_COLLECTOR_HOST
+          value: "{{ .Values.analyticsCollectorHost }}"
+        - name: ANALYTICS_COLLECTOR_API_TOKEN
+          value: "{{ .Values.analyticsCollectorApiToken }}"
+        - name: OTEL_TRACING_PRINT
+          value: "{{ .Values.otelTracingPrint }}"
+        - name: LOGS_COLLECTOR_ADDRESS
+          value: "{{ .Values.logsCollectorAddress }}"
+        - name: OTEL_COLLECTOR_GRPC_ENDPOINT
+          value: "{{ .Values.otelCollectorGrpcEndpoint }}"
+        - name: ADMIN_TOKEN
+          value: "{{ .Values.apiAdminToken }}"
+        - name: REDIS_URL
+          value: "{{ .Values.redisUrl }}:{{ .Values.redisPort | int }}"
+        - name: REDIS_CLUSTER_URL
+          value: "{{ .Values.redisClusterUrl }}"
+        - name: SANDBOX_ACCESS_TOKEN_HASH_SEED
+          value: "{{ .Values.sandboxAccessTokenHashSeed }}"
+        - name: TEMPLATE_BUCKET_NAME
+          value: "{{ .Values.templateBucketName }}"
+        - name: LOKI_URL
+          value: "{{ .Values.lokiUrl }}"
+        - name: SANDBOX_STORAGE_BACKEND
+          value: "{{ .Values.sandboxStorageBackend }}"
+        resources:
+          requests:
+            cpu: 2000m
+            memory: 2048Mi
+          limits:
+            cpu: 2000m
+            memory: 4096Mi
+        livenessProbe:
+          httpGet:
+            path: /health
+            port: api
+            host: 127.0.0.1
+          initialDelaySeconds: 30
+          periodSeconds: 3
+          timeoutSeconds: 3
+        readinessProbe:
+          httpGet:
+            path: /health
+            port: api
+            host: 127.0.0.1
+          initialDelaySeconds: 30
+          periodSeconds: 3
+          timeoutSeconds: 3
+        lifecycle:
+          preStop:
+            exec:
+              command: ["/bin/sh","-c","sleep 30"]
+---
+apiVersion: v1
+kind: Service
+metadata:
+  name: api
+  namespace: e2b
+  labels:
+    app: api
+spec:
+  type: ClusterIP
+  selector:
+    app: api
+  ports:
+  - port: {{ .Values.apiPort | int }}
+    targetPort: api
+    name: api
+  - port: {{ .Values.dnsPort | int }}
+    targetPort: dns
+    name: dns
+    protocol: UDP
diff --git a/helm/templates/clickhouse.yaml b/helm/templates/clickhouse.yaml
new file mode 100644
index 0000000..8cdd5ec
--- /dev/null
+++ b/helm/templates/clickhouse.yaml
@@ -0,0 +1,337 @@
+# clickhouse.yaml
+apiVersion: v1
+kind: ConfigMap
+metadata:
+  name: clickhouse-config
+  namespace: e2b
+data:
+  config.xml: |
+    <clickhouse>
+        <!-- this is undocumented but needed to enable waiting for for shutdown for a custom amount of time  -->
+        <!-- see https://github.com/ClickHouse/ClickHouse/pull/77515 for more details  -->
+        <shutdown_wait_unfinished>60</shutdown_wait_unfinished>
+        <shutdown_wait_unfinished_queries>1</shutdown_wait_unfinished_queries>
+
+        <!-- Use up 80% of available RAM to be on the safer side, default is 90% -->
+        <max_server_memory_usage_to_ram_ratio>0.8</max_server_memory_usage_to_ram_ratio>
+
+        <logger>
+            <formatting>
+                <type>json</type>
+                <names>
+                    <date_time>date_time</date_time>
+                    <thread_id>thread_id</thread_id>
+                    <level>level</level>
+                    <query_id>query_id</query_id>
+                    <logger_name>logger_name</logger_name>
+                    <message>message</message>
+                    <source_file>source_file</source_file>
+                    <source_line>source_line</source_line>
+                </names>
+            </formatting>
+            <console>1</console>
+            <level>information</level>
+        </logger>
+
+        <default_replica_path>/var/lib/clickhouse/tables/{shard}/{database}/{table}</default_replica_path>
+        <remote_servers replace="true">
+            <cluster>
+                <secret>{{ .Values.clickhouseServerSecret }}</secret>
+                <shard>
+                    <replica>
+                        <host>clickhouse.e2b.svc.cluster.local</host>
+                        <port>{{ .Values.clickhouseServerPort }}</port>
+                        <user>{{ .Values.clickhouseUsername }}</user>
+                        <password>{{ .Values.clickhousePassword }}</password>
+                    </replica>
+                </shard>
+            </cluster>
+        </remote_servers>
+
+        <listen_host>0.0.0.0</listen_host>
+
+        <asynchronous_metric_log><ttl>event_date + INTERVAL 7 DAY</ttl></asynchronous_metric_log>
+
+        <trace_log><ttl>event_date + INTERVAL 7 DAY</ttl></trace_log>
+
+        <text_log><ttl>event_date + INTERVAL 7 DAY</ttl></text_log>
+
+        <latency_log><ttl>event_date + INTERVAL 7 DAY</ttl></latency_log>
+
+        <query_log><ttl>event_date + INTERVAL 7 DAY</ttl></query_log>
+
+        <metric_log><ttl>event_date + INTERVAL 7 DAY</ttl></metric_log>
+
+        <processors_profile_log><ttl>event_date + INTERVAL 7 DAY</ttl></processors_profile_log>
+
+        <part_log><ttl>event_date + INTERVAL 7 DAY</ttl></part_log>
+
+        <query_metrics_log><ttl>event_date + INTERVAL 7 DAY</ttl></query_metrics_log>
+
+        <error_log><ttl>event_date + INTERVAL 30 DAY</ttl></error_log>
+
+        <prometheus>
+            <port>{{ .Values.clickhouseMetricPort }}</port>
+            <endpoint>/metrics</endpoint>
+            <metrics>true</metrics>
+            <asynchronous_metrics>true</asynchronous_metrics>
+            <events>true</events>
+            <errors>true</errors>
+        </prometheus>
+        <tcp_port>{{ .Values.clickhouseServerPort }}</tcp_port>
+    </clickhouse>
+
+  users.xml: |
+    <clickhouse>
+        <users>
+            <{{ .Values.clickhouseUsername }}>
+                <password>{{ .Values.clickhousePassword }}</password>
+                <networks>
+                    <ip>172.26.64.0/20</ip>
+                    <ip>::1</ip>
+                    <ip>10.0.0.0/8</ip>
+                    <ip>127.0.0.1</ip>
+                </networks>
+                <profile>default</profile>
+                <async_insert>1</async_insert>
+                <wait_for_async_insert>1</wait_for_async_insert>
+                <quota>default</quota>
+                <access_management>1</access_management>
+            </{{ .Values.clickhouseUsername }}>
+        </users>
+    </clickhouse>
+
+  otel.yaml: |
+    receivers:
+      prometheus:
+        config:
+          scrape_configs:
+            - job_name: "clickhouse"
+              scrape_interval: 30s
+              metrics_path: /metrics
+              static_configs:
+                - targets: ['localhost:{{ .Values.clickhouseMetricPort }}']
+    exporters:
+      otlp:
+        endpoint: http://localhost:{{ .Values.clickhouseServerPort }}
+        tls:
+          insecure: true
+    processors:
+      batch: {}
+      resourcedetection:
+        detectors: [gcp]
+        override: true
+        gcp:
+          resource_attributes:
+            host.type: { enabled: true }
+            host.id:   { enabled: true }
+            gcp.gce.instance.name: { enabled: true }
+            host.name: { enabled: true }
+      transform/set-name:
+        metric_statements:
+          - set(datapoint.attributes["service.instance.id"], resource.attributes["gcp.gce.instance.name"])
+      filter:
