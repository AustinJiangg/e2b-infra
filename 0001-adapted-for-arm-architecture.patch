+			NomadNodeShortID:    node.ID[:consts.NodeIDLength],
+			OrchestratorAddress: fmt.Sprintf("%s:%d", node.Address, consts.OrchestratorAPIPort),
+			IPAddress:           node.Address,
+		})
+	}
+	return out, nil
+}
