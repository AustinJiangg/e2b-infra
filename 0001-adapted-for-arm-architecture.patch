diff --git a/packages/orchestrator/internal/template/build/phases/base/provision.sh b/packages/orchestrator/internal/template/build/phases/base/provision.sh
index 894d4a6..a441278 100644
--- a/packages/orchestrator/internal/template/build/phases/base/provision.sh
+++ b/packages/orchestrator/internal/template/build/phases/base/provision.sh
@@ -9,13 +9,50 @@ echo "Starting provisioning script"
 echo "Making configuration immutable"
 $BUSYBOX chattr +i /etc/resolv.conf
 
+# Detect OS family
+if [ -f /etc/os-release ]; then
+    . /etc/os-release
+    OS_ID="$ID"
+else
+    echo "Cannot detect OS. /etc/os-release not found."
+    exit 1
+fi
+
 # Helper function to check if a package is installed
 is_package_installed() {
-    dpkg-query -W -f='${Status}' "$1" 2>/dev/null | grep -q "install ok installed"
+    local pkg="$1"
+    if [[ "$OS_ID" == "ubuntu" || "$OS_ID" == "debian" ]]; then
+        dpkg-query -W -f='${Status}' "$pkg" 2>/dev/null | grep -q "install ok installed"
+    elif [[ "$OS_ID" == "openEuler" || "$OS_ID" == "rhel" || "$OS_ID" == "centos" || "$OS_ID" == "fedora" ]]; then
+        rpm -q "$pkg" &>/dev/null
+    else
+        echo "Unsupported OS: $OS_ID"
+        return 1
+    fi
+}
+
+# Helper: install missing packages
+install_packages() {
+    local missing="$1"
+    if [ -z "$missing" ]; then
+        return 0
+    fi
+
+    if [[ "$OS_ID" == "ubuntu" || "$OS_ID" == "debian" ]]; then
+        echo "Updating apt cache..."
+        apt-get -q update
+        DEBIAN_FRONTEND=noninteractive DEBCONF_NOWARNINGS=yes \
+            apt-get -qq -o=Dpkg::Use-Pty=0 install -y --no-install-recommends $missing
+    elif [[ "$OS_ID" == "openEuler" || "$OS_ID" == "rhel" || "$OS_ID" == "centos" || "$OS_ID" == "fedora" ]]; then
+        echo "Installing via dnf: $missing"
+        dnf install --nogpgcheck -y $missing
+    fi
 }
 
 # Install required packages if not already installed
-PACKAGES="systemd systemd-sysv openssh-server sudo chrony linuxptp socat curl ca-certificates fuse3 iptables git nfs-common"
+PACKAGES="systemd systemd-sysv openssh-server sudo chrony linuxptp socat curl ca-certificates"
+
+echo "OS detected: $OS_ID"
 echo "Checking presence of the following packages: $PACKAGES"
 
 MISSING=""
@@ -23,13 +60,14 @@ for pkg in $PACKAGES; do
     if ! is_package_installed "$pkg"; then
         echo "Package $pkg is missing, will install it."
         MISSING="$MISSING $pkg"
+    else
+        echo "Package $pkg is already installed."
     fi
 done
 
 if [ -n "$MISSING" ]; then
     echo "Missing packages detected, installing:$MISSING"
-    apt-get -q update
-    DEBIAN_FRONTEND=noninteractive DEBCONF_NOWARNINGS=yes apt-get -qq -o=Dpkg::Use-Pty=0 install -y --no-install-recommends $MISSING
+    install_packages "$MISSING"
 else
     echo "All required packages are already installed."
 fi
diff --git a/packages/orchestrator/internal/template/build/phases/finalize/configure.sh b/packages/orchestrator/internal/template/build/phases/finalize/configure.sh
index 76202a8..516185a 100644
--- a/packages/orchestrator/internal/template/build/phases/finalize/configure.sh
+++ b/packages/orchestrator/internal/template/build/phases/finalize/configure.sh
@@ -1,6 +1,5 @@
-#!/bin/bash
-export BASH_XTRACEFD=1
-set -euo pipefail
+#!/bin/sh
+set -e
 
 echo "Starting configuration script"
 
@@ -10,21 +9,54 @@ TEMPLATE_ID={{ .TemplateID }}
 BUILD_ID={{ .BuildID }}
 EOF
 
+# 检测系统类型：Debian/Ubuntu 会存在此文件，openEuler/RHEL 不存在
+IS_DEBIAN=0
+if test -f /etc/debian_version; then
+    IS_DEBIAN=1
+    echo "Detected Debian-based system"
+else
+    echo "Detected RHEL-based system (openEuler/CentOS/RHEL)"
+fi
+
 # Create default user.
-# if the /home/user directory exists, we copy the skeleton files to it because the adduser command
-# will ignore the directory if it exists, but we want to include the skeleton files in the home directory
-# in our case.
 echo "Create default user 'user' (if doesn't exist yet)"
-ADDUSER_OUTPUT=$(adduser -disabled-password --gecos "" user 2>&1 || true)
-echo "$ADDUSER_OUTPUT"
-if echo "$ADDUSER_OUTPUT" | grep -q "The home directory \`/home/user' already exists"; then
-    # Copy skeleton files if they don't exist in the home directory
-    echo "Copy skeleton files to /home/user"
-    cp -rn /etc/skel/. /home/user/
+
+if [ "$IS_DEBIAN" -eq 1 ]; then
+    ADDUSER_OUTPUT=$(adduser --disabled-password --gecos "" user 2>&1 || true)
+    echo "$ADDUSER_OUTPUT"
+    if echo "$ADDUSER_OUTPUT" | grep -q "The home directory \`/home/user' already exists"; then
+        # Copy skeleton files if they don't exist in the home directory
+        echo "Copy skeleton files to /home/user"
+        cp -rn /etc/skel/. /home/user/
+    fi
+else
+    if ! id -u user >/dev/null 2>&1; then
+        echo "Creating user with useradd"
+        # 如果家目录已存在，useradd -m 会报错，需要先检查
+        if [ -d /home/user ]; then
+            # 家目录已存在，不自动创建（-M），后续手动处理
+            useradd -M -s /bin/bash -c "" user
+        else
+            # 正常创建用户和家目录
+            useradd -m -s /bin/bash -c "" user
+        fi
+    fi
+    # 无论如何都确保骨架文件被复制（-n 表示不覆盖已有文件）
+    if [ -d /etc/skel ] && [ -d /home/user ]; then
+        echo "Copy skeleton files to /home/user"
+        cp -rn /etc/skel/. /home/user/
+    fi
 fi
 
 echo "Add sudo to 'user' with no password"
-usermod -aG sudo user
+if [ "$IS_DEBIAN" -eq 1 ]; then
+    # Debian/Ubuntu 使用 sudo 组
+    usermod -aG sudo user
+else
+    # openEuler/RHEL 使用 wheel 组[^4^][^10^]
+    usermod -aG wheel user
+fi
+
 passwd -d user
 echo "user ALL=(ALL:ALL) NOPASSWD: ALL" >>/etc/sudoers
 
@@ -41,3 +73,4 @@ echo "Give 777 permission to /code"
 chmod 777 -R /code
 
 echo "Finished configuration script"
+
