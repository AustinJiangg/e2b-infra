+        - name: ORCHESTRATOR_PORT
+          value: "{{ .Values.orchestratorPort | int }}"
+        - name: SERVICE_DISCOVERY_ORCHESTRATOR_PROVIDER
+          value: DNS
+        - name: SERVICE_DISCOVERY_ORCHESTRATOR_DNS_RESOLVER_ADDRESS
+          value: 10.233.0.3:53
+        - name: SERVICE_DISCOVERY_ORCHESTRATOR_DNS_QUERY
+          value: template-manager.e2b.svc.cluster.local
+        - name: SERVICE_DISCOVERY_EDGE_PROVIDER
+          value: DNS
+        - name: SERVICE_DISCOVERY_EDGE_DNS_RESOLVER_ADDRESS
+          value: 10.233.0.3:53
+        - name: SERVICE_DISCOVERY_EDGE_DNS_QUERY
+          value: edge-api.e2b.svc.cluster.local
+        - name: ENVIRONMENT
+          value: dev
+        - name: USE_PROXY_CATALOG_RESOLUTION
+          value: "false"
+        - name: OTEL_COLLECTOR_GRPC_ENDPOINT
+          value: "{{ .Values.otelCollectorGrpcEndpoint }}"
+        - name: LOGS_COLLECTOR_ADDRESS
+          value: "{{ .Values.logsCollectorAddress }}"
+        - name: REDIS_URL
+          value: "{{ .Values.redisUrl }}:{{ .Values.redisPort | int }}"
+        - name: REDIS_CLUSTER_URL
+          value: ""
+        - name: LOKI_URL
+          value: "{{ .Values.lokiUrl }}"
+        - name: API_GRPC_ADDRESS
+          value: "{{ .Values.apiGrpcAddress }}"
+        resources:
+          requests:
+            cpu: {{ .Values.clientProxyResourcesCpuCount }}m
+            memory: {{ .Values.clientProxyResourcesMemoryMb }}Mi
+          limits:
+            cpu: {{ .Values.clientProxyResourcesCpuCount }}m
+            memory: {{ .Values.clientProxyMaxResourcesMemoryMb }}Mi
+        livenessProbe:
+          httpGet: { path: /health/traffic, port: health }
