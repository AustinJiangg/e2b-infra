+spec:
+  selector:
+    matchLabels: { app: orchestrator }
+  template:
+    metadata:
+      labels: { app: orchestrator }
+    spec:
+      hostPID: true
+      hostNetwork: true
+      dnsPolicy: ClusterFirstWithHostNet
+      affinity:
+        nodeAffinity:
+          requiredDuringSchedulingIgnoredDuringExecution:
+            nodeSelectorTerms:
+            - matchExpressions:
+              - key: node-role.kubernetes.io/{{ .Values.default.pool }}
+                operator: Exists
+      containers:
+      - name: orchestrator
+        volumeMounts:
+        - name: hugepages
+          mountPath: /mnt/hugepages
+        - name: snapshot-cache
+          mountPath: /mnt/snapshot-cache
+        - name: host-dev
+          mountPath: /dev
+        - name: build-cache
+          mountPath: /orchestrator
+        - name: dev-net-tun
+          mountPath: /dev/net/tun
+        - name: fc-envd
+          mountPath: /fc-envd
+        - name: fc-kernels
+          mountPath: /fc-kernels
+        - name: fc-versions
+          mountPath: /fc-versions
+        - name: fc-vm
+          mountPath: /fc-vm
+        - name: tmp-templates
+          mountPath: /tmp/templates
+        securityContext:
+          privileged: true
+        image: {{ .Values.registry }}/orchestrator
+        imagePullPolicy: IfNotPresent
+        command: ["/usr/bin/orchestrator"]
+        args: ["--port", "{{ .Values.orchestratorPort | int }}", "--proxy-port", "{{ .Values.orchestratorProxyPort | int }}"]
+        ports:
+        - containerPort: {{ .Values.orchestratorPort | int }}
+          name: grpc
+        env:
+        - name: NODE_ID
+          valueFrom: { fieldRef: { fieldPath: spec.nodeName } }
+        - name: OTEL_TRACING_PRINT
+          value: "{{ .Values.otelTracingPrint }}"
+        - name: ENVIRONMENT
+          value: "{{ .Values.environment }}"
+        - name: TEMPLATE_BUCKET_NAME
+          value: "{{ .Values.templateBucketName }}"
