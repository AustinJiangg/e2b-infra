+			{Op: launchplan.OpMkdir, Path: kernelDir},
+			{Op: launchplan.OpSymlink, Path: filepath.Join(kernelDir, args.SandboxKernelFile), Src: args.HostKernelPath},
+		}
+	}
+
+	return &LaunchPlanResult{
+		Plan: launchplan.Plan{
+			Steps:             steps,
+			NamespaceID:       args.NamespaceID,
+			FirecrackerPath:   args.FirecrackerPath,
+			FirecrackerSocket: args.FirecrackerSocket,
+		},
+		RootfsPath: sb.getRootfsPath(args, rootfsPaths),
+		KernelPath: sb.getKernelPath(args),
+	}, nil
+}
+
+// HelperArgv encodes the plan as the ordered argv flag list for the
+// fc-launch-c helper (launch-c mode). Defined here, next to BuildLaunchPlan,
+// so process.go needs no launchplan import.
+func (r *LaunchPlanResult) HelperArgv() ([]string, error) {
+	return launchplan.Argv(r.Plan)
+}
