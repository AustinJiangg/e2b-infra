diff --git a/packages/orchestrator/cmd/fc-launch/main.go b/packages/orchestrator/cmd/fc-launch/main.go
new file mode 100644
index 0000000..322a598
--- /dev/null
+++ b/packages/orchestrator/cmd/fc-launch/main.go
@@ -0,0 +1,52 @@
+//go:build linux
+
+// Command fc-launch starts a firecracker process from a JSON launch plan (see
+// package launchplan). It is the "launch" mode helper.
+//
+// The orchestrator starts this binary through a minimal
+// `unshare --mount --propagation unchanged` wrapper — a fresh mount namespace
+// created in the child, with no recursive remount of "/" — instead of the old
+// shell pipeline
+//
+//	unshare -m -- bash -c "mount --make-rprivate / && mount -t tmpfs ... && \
+//	    ln -s ... && mkdir -p ... && ln -s ... && \
+//	    ip netns exec <ns> <firecracker> --api-sock <sock>"
+//
+// (bash + coreutils mount/ln/mkdir + iproute2's `ip` = ~8 fork/exec per
+// sandbox). fc-launch performs the per-sandbox mount/symlink setup, enters the
+// sandbox network namespace and execs firecracker, all via direct syscalls in a
+// single tiny process: no bash, no coreutils, no iproute2, and — unlike
+// re-execing the orchestrator itself — no heavy package init() on the launch
+// critical path.
+package main
+
+import (
+	"encoding/json"
+	"fmt"
+	"os"
+
+	"github.com/e2b-dev/infra/packages/orchestrator/internal/sandbox/fc/launchplan"
+)
+
+func main() {
+	if len(os.Args) < 2 {
+		fmt.Fprintf(os.Stderr, "usage: %s <json-launch-plan>\n", os.Args[0])
+		os.Exit(2)
+	}
+
+	var plan launchplan.Plan
+	if err := json.Unmarshal([]byte(os.Args[1]), &plan); err != nil {
+		fmt.Fprintf(os.Stderr, "fc-launch: invalid launch plan: %v\n", err)
+		os.Exit(1)
+	}
+
+	if err := launchplan.Run(plan); err != nil {
+		fmt.Fprintf(os.Stderr, "fc-launch: %v\n", err)
+		os.Exit(1)
+	}
+
+	// Run execs firecracker on success and never returns; reaching here means
+	// execve did not replace the process image.
+	fmt.Fprintln(os.Stderr, "fc-launch: launcher returned without exec")
+	os.Exit(1)
+}
diff --git a/packages/orchestrator/cmd/fc-launch-c/fc_launch.c b/packages/orchestrator/cmd/fc-launch-c/fc_launch.c
new file mode 100644
index 0000000..6cd7fab
--- /dev/null
+++ b/packages/orchestrator/cmd/fc-launch-c/fc_launch.c
@@ -0,0 +1,200 @@
+// fc-launch-c — the "launch-c" (gear 4) firecracker launcher.
+//
+// Single-threaded C replacement for the Go fc-launch helper (gear 3,
+// "launch"). Because it is single-threaded it may call unshare(CLONE_NEWNS)
+// itself after execve — impossible in Go, whose runtime threads share their
+// fs_struct so unshare(2) fails with EINVAL — so the orchestrator spawns this
+// binary directly: no `unshare --mount --propagation unchanged` wrapper (one
+// execve less) and no Go runtime startup (~1-2ms) on the launch path.
+//
+// The launch plan arrives as ordered argv flags instead of JSON: execve
+// passes argv verbatim (no shell, no quoting layer), and C then needs no JSON
+// parser. Step flags execute strictly in argv order and mirror
+// startScriptV1/V2 exactly like launchplan.Plan.Steps (see launchplan.Argv).
+//
+// Usage:
+//   fc-launch-c --netns <name|/abs/path> --fc <firecracker> --sock <api-sock>
+//               [--tmpfs <dir> | --symlink <link> <target> | --mkdir <dir>]...
+//
+// Propagation handling matches launchplan.Run: the fresh mount namespace
+// still shares propagation with the host, so the mount containing every
+// --tmpfs target is marked MS_PRIVATE non-recursively (walking up on
+// EINVAL/ENOENT; "/" always terminates the walk) — O(path depth) syscalls,
+// never the O(host-mounts) recursive remount.
+
+#define _GNU_SOURCE
+#include <errno.h>
+#include <fcntl.h>
+#include <limits.h>
+#include <sched.h>
+#include <stdio.h>
+#include <stdlib.h>
+#include <string.h>
+#include <sys/mount.h>
+#include <sys/stat.h>
+#include <unistd.h>
+
+extern char **environ;
+
+static void die(const char *what, const char *arg) {
+	if (arg != NULL)
+		fprintf(stderr, "fc-launch-c: %s %s: %s\n", what, arg, strerror(errno));
+	else
+		fprintf(stderr, "fc-launch-c: %s: %s\n", what, strerror(errno));
+	exit(1);
+}
+
+static void usage(void) {
+	fprintf(stderr,
+	        "usage: fc-launch-c --netns <name|path> --fc <firecracker> --sock <api-sock>\n"
+	        "                   [--tmpfs <dir> | --symlink <link> <target> | --mkdir <dir>]...\n");
+	exit(2);
+}
+
+// copy_path bounds-checks an argv path (absolute, fits PATH_MAX) and copies it
+// into a fixed buffer the walk/mkdir helpers can edit in place.
+static void copy_path(char *dst, size_t cap, const char *path, const char *what) {
+	size_t n = strlen(path);
+	if (n == 0 || path[0] != '/' || n >= cap) {
+		errno = (n >= cap) ? ENAMETOOLONG : EINVAL;
+		die(what, path);
+	}
+	memcpy(dst, path, n + 1);
+}
+
+// mkdir -p, mode 0755 (mirrors os.MkdirAll in the Go helper).
+static void mkdir_p(const char *path) {
+	char buf[PATH_MAX];
+	copy_path(buf, sizeof(buf), path, "mkdir -p");
+	for (char *p = buf + 1; *p != '\0'; p++) {
+		if (*p != '/')
+			continue;
+		*p = '\0';
+		if (mkdir(buf, 0755) != 0 && errno != EEXIST)
+			die("mkdir -p", path);
+		*p = '/';
+	}
+	if (mkdir(buf, 0755) != 0 && errno != EEXIST)
+		die("mkdir -p", path);
+}
+
+// make_containing_mount_private marks the mount containing path MS_PRIVATE
+// (non-recursive) so mounts later placed at path do not propagate to peer
+// namespaces. MS_PRIVATE on a non-mount-point fails with EINVAL, and
+// components that do not exist yet (created by a later step) fail with ENOENT
+// — both mean "try the parent". "/" is always a mount point, so the walk
+// terminates.
+static void make_containing_mount_private(const char *path) {
+	char buf[PATH_MAX];
+	copy_path(buf, sizeof(buf), path, "make mount private");
+	for (;;) {
+		if (mount("", buf, NULL, MS_PRIVATE, NULL) == 0)
+			return;
+		if ((errno != EINVAL && errno != ENOENT) || strcmp(buf, "/") == 0)
+			die("make mount private", path);
+		char *slash = strrchr(buf, '/');
+		if (slash == buf)
+			buf[1] = '\0'; // parent of "/x" is "/"
+		else
+			*slash = '\0';
+	}
+}
+
+// open_netns resolves a namespace name under /var/run/netns then /run/netns
+// (iproute2's lookup order); an absolute path is used as-is.
+static int open_netns(const char *ns) {
+	if (ns[0] == '/') {
+		int fd = open(ns, O_RDONLY | O_CLOEXEC);
+		if (fd < 0)
+			die("open netns", ns);
+		return fd;
+	}
+
+	static const char *const dirs[] = {"/var/run/netns", "/run/netns"};
+	for (size_t i = 0; i < sizeof(dirs) / sizeof(dirs[0]); i++) {
+		char buf[PATH_MAX];
+		int n = snprintf(buf, sizeof(buf), "%s/%s", dirs[i], ns);
+		if (n < 0 || (size_t)n >= sizeof(buf)) {
+			errno = ENAMETOOLONG;
+			die("open netns", ns);
+		}
+		int fd = open(buf, O_RDONLY | O_CLOEXEC);
+		if (fd >= 0)
+			return fd;
+	}
+	die("open netns", ns); // errno from the last open attempt
+	return -1;             // unreachable
+}
+
+int main(int argc, char **argv) {
+	const char *netns = NULL, *fc = NULL, *sock = NULL;
+
+	// Pass 1: collect config flags and validate the whole argv shape, so a
+	// malformed invocation fails before anything is mutated.
+	for (int i = 1; i < argc; i++) {
+		const char *a = argv[i];
+		if (strcmp(a, "--netns") == 0 && i + 1 < argc)
+			netns = argv[++i];
+		else if (strcmp(a, "--fc") == 0 && i + 1 < argc)
+			fc = argv[++i];
+		else if (strcmp(a, "--sock") == 0 && i + 1 < argc)
+			sock = argv[++i];
+		else if ((strcmp(a, "--tmpfs") == 0 || strcmp(a, "--mkdir") == 0) && i + 1 < argc)
+			i += 1;
+		else if (strcmp(a, "--symlink") == 0 && i + 2 < argc)
+			i += 2;
+		else
+			usage();
+	}
+	if (netns == NULL || fc == NULL || sock == NULL)
+		usage();
+
+	// Own mount namespace. A single-threaded process may unshare(CLONE_NEWNS)
+	// directly, and unlike unshare(1)'s default or Go's Unshareflags path,
+	// nothing here remounts "/" recursively — propagation is cut per target
+	// below.
+	if (unshare(CLONE_NEWNS) != 0)
+		die("unshare(CLONE_NEWNS)", NULL);
+
+	// Cut propagation for every tmpfs target...
+	for (int i = 1; i < argc; i++) {
+		if (strcmp(argv[i], "--tmpfs") == 0)
+			make_containing_mount_private(argv[++i]);
+		else if (strcmp(argv[i], "--symlink") == 0)
+			i += 2;
+		else
+			i += 1; // value of --netns/--fc/--sock/--mkdir
+	}
+
+	// ...then execute the steps in argv order (mirrors launchplan.Run).
+	for (int i = 1; i < argc; i++) {
+		const char *a = argv[i];
+		if (strcmp(a, "--tmpfs") == 0) {
+			const char *dir = argv[++i];
+			mkdir_p(dir);
+			if (mount("tmpfs", dir, "tmpfs", 0, NULL) != 0)
+				die("mount tmpfs", dir);
+		} else if (strcmp(a, "--mkdir") == 0) {
+			mkdir_p(argv[++i]);
+		} else if (strcmp(a, "--symlink") == 0) {
+			const char *link_path = argv[++i];
+			const char *target = argv[++i];
+			if (symlink(target, link_path) != 0)
+				die("symlink", link_path);
+		} else {
+			i++; // value of --netns/--fc/--sock
+		}
+	}
+
+	// Enter the sandbox network namespace, then exec firecracker in place; the
+	// process is still single-threaded, so no thread pinning is needed (this
+	// is what `ip netns exec` does, minus its mount-namespace/sysfs work).
+	int fd = open_netns(netns);
+	if (setns(fd, CLONE_NEWNET) != 0)
+		die("setns(CLONE_NEWNET)", netns);
+	close(fd);
+
+	char *fc_argv[] = {(char *)fc, "--api-sock", (char *)sock, NULL};
+	execve(fc, fc_argv, environ);
+	die("exec firecracker", fc); // execve only returns on failure
+}
diff --git a/packages/orchestrator/cmd/fc-netns-exec/main.go b/packages/orchestrator/cmd/fc-netns-exec/main.go
new file mode 100644
index 0000000..dcedfb8
--- /dev/null
+++ b/packages/orchestrator/cmd/fc-netns-exec/main.go
@@ -0,0 +1,74 @@
+//go:build linux
+
+package main
+
+import (
+	"fmt"
+	"os"
+	"path/filepath"
+	"runtime"
+	"time"
+
+	"golang.org/x/sys/unix"
+)
+
+const netnsDir = "/run/netns"
+
+func main() {
+	if len(os.Args) < 3 {
+		fmt.Fprintf(os.Stderr, "usage: %s <netns-name-or-path> <command> [args...]\n", os.Args[0])
+		os.Exit(2)
+	}
+
+	namespace := os.Args[1]
+	command := os.Args[2]
+	commandArgs := os.Args[2:]
+
+	runtime.LockOSThread()
+
+	nsPath := namespacePath(namespace)
+	fd, err := unix.Open(nsPath, unix.O_RDONLY|unix.O_CLOEXEC, 0)
+	if err != nil {
+		fmt.Fprintf(os.Stderr, "fc-netns-exec: open network namespace %q: %v\n", nsPath, err)
+		os.Exit(1)
+	}
+	defer unix.Close(fd)
+
+	if err := unix.Setns(fd, unix.CLONE_NEWNET); err != nil {
+		fmt.Fprintf(os.Stderr, "fc-netns-exec: setns(%q, CLONE_NEWNET): %v\n", nsPath, err)
+		os.Exit(1)
+	}
+
+	if os.Getenv("E2B_FC_START_SCRIPT_DIAG") == "1" {
+		fmt.Fprintf(
+			os.Stderr,
+			"e2b_fc_start_script_marker stage=inside_netns_before_firecracker_exec ns=%d socket=%s namespace=%s\n",
+			time.Now().UnixNano(),
+			findArgValue(commandArgs, "--api-sock"),
+			namespace,
+		)
+	}
+
+	if err := unix.Exec(command, commandArgs, os.Environ()); err != nil {
+		fmt.Fprintf(os.Stderr, "fc-netns-exec: exec %q: %v\n", command, err)
+		os.Exit(1)
+	}
+}
+
+func namespacePath(namespace string) string {
+	if filepath.IsAbs(namespace) {
+		return filepath.Clean(namespace)
+	}
+
+	return filepath.Join(netnsDir, namespace)
+}
+
+func findArgValue(args []string, name string) string {
+	for i := 0; i+1 < len(args); i++ {
+		if args[i] == name {
+			return args[i+1]
+		}
+	}
+
+	return ""
+}
diff --git a/packages/orchestrator/internal/sandbox/fc/launchplan/argv.go b/packages/orchestrator/internal/sandbox/fc/launchplan/argv.go
new file mode 100644
index 0000000..744165b
--- /dev/null
+++ b/packages/orchestrator/internal/sandbox/fc/launchplan/argv.go
@@ -0,0 +1,31 @@
+package launchplan
+
+import "fmt"
+
+// Argv encodes a Plan as the ordered flag list understood by the fc-launch-c
+// helper (launch-c mode). Like the JSON form handed to the Go fc-launch
+// helper, argv is passed verbatim by execve — no shell, no quoting layer —
+// but flags additionally need no parser at all on the C side. Step flags keep
+// Plan.Steps order; the helper executes them in argv order.
+func Argv(p Plan) ([]string, error) {
+	args := []string{
+		"--netns", p.NamespaceID,
+		"--fc", p.FirecrackerPath,
+		"--sock", p.FirecrackerSocket,
+	}
+
+	for _, s := range p.Steps {
+		switch s.Op {
+		case OpTmpfs:
+			args = append(args, "--tmpfs", s.Path)
+		case OpMkdir:
+			args = append(args, "--mkdir", s.Path)
+		case OpSymlink:
+			args = append(args, "--symlink", s.Path, s.Src)
+		default:
+			return nil, fmt.Errorf("unknown op %q", s.Op)
+		}
+	}
+
+	return args, nil
+}
diff --git a/packages/orchestrator/internal/sandbox/fc/launchplan/argv_test.go b/packages/orchestrator/internal/sandbox/fc/launchplan/argv_test.go
new file mode 100644
index 0000000..1ec8fcf
--- /dev/null
+++ b/packages/orchestrator/internal/sandbox/fc/launchplan/argv_test.go
@@ -0,0 +1,44 @@
+package launchplan
+
+import (
+	"reflect"
+	"testing"
+)
+
+func TestArgv(t *testing.T) {
+	plan := Plan{
+		Steps: []Step{
+			{Op: OpTmpfs, Path: "/fc-vm"},
+			{Op: OpSymlink, Path: "/fc-vm/rootfs.ext4", Src: "/orchestrator/sandbox/rootfs"},
+			{Op: OpMkdir, Path: "/fc-vm/kernel"},
+			{Op: OpSymlink, Path: "/fc-vm/kernel/vmlinux.bin", Src: "/fc-kernels/vmlinux.bin"},
+		},
+		NamespaceID:       "ns-7",
+		FirecrackerPath:   "/fc-versions/v1.12.1/firecracker",
+		FirecrackerSocket: "/run/fc.sock",
+	}
+
+	got, err := Argv(plan)
+	if err != nil {
+		t.Fatal(err)
+	}
+
+	want := []string{
+		"--netns", "ns-7",
+		"--fc", "/fc-versions/v1.12.1/firecracker",
+		"--sock", "/run/fc.sock",
+		"--tmpfs", "/fc-vm",
+		"--symlink", "/fc-vm/rootfs.ext4", "/orchestrator/sandbox/rootfs",
+		"--mkdir", "/fc-vm/kernel",
+		"--symlink", "/fc-vm/kernel/vmlinux.bin", "/fc-kernels/vmlinux.bin",
+	}
+	if !reflect.DeepEqual(got, want) {
+		t.Fatalf("Argv:\n got %q\nwant %q", got, want)
+	}
+}
+
+func TestArgvUnknownOp(t *testing.T) {
+	if _, err := Argv(Plan{Steps: []Step{{Op: "chmod", Path: "/x"}}}); err == nil {
+		t.Fatal("want error for unknown op")
+	}
+}
diff --git a/packages/orchestrator/internal/sandbox/fc/launchplan/plan.go b/packages/orchestrator/internal/sandbox/fc/launchplan/plan.go
new file mode 100644
index 0000000..2f69fba
--- /dev/null
+++ b/packages/orchestrator/internal/sandbox/fc/launchplan/plan.go
@@ -0,0 +1,47 @@
+// Package launchplan defines the shell-free description of how to start a
+// firecracker process and (on Linux) executes it.
+//
+// It is intentionally tiny and imports only the standard library (plus
+// golang.org/x/sys/unix for the execution half) so that the fc-launch helper
+// binary built from it stays small and has negligible startup cost. This is the
+// key difference from re-execing the whole orchestrator binary: there, every
+// imported package's init() would run on each sandbox launch and land on the
+// "wait firecracker start" critical path. A dedicated helper pays none of that.
+package launchplan
+
+// StepOp enumerates the filesystem operations performed inside the sandbox's
+// private mount namespace. They mirror the orchestrator's startScriptV1/V2.
+type StepOp string
+
+const (
+	OpMkdir   StepOp = "mkdir"   // mkdir -p <Path>
+	OpTmpfs   StepOp = "tmpfs"   // mkdir -p <Path> && mount -t tmpfs tmpfs <Path>
+	OpSymlink StepOp = "symlink" // ln -s <Src> <Path>
+)
+
+// Step is a single ordered filesystem-setup operation.
+type Step struct {
+	Op   StepOp `json:"op"`
+	Path string `json:"path"`
+	Src  string `json:"src,omitempty"`
+}
+
+// Plan fully describes how to start a firecracker process. It is the shell-free
+// replacement for the generated start script: NewProcess JSON-encodes it and
+// passes it to the re-exec'd fc-launch helper as a single argv element (exec
+// passes argv as a slice, so no shell quoting is involved).
+type Plan struct {
+	// Steps are mount-namespace filesystem operations, executed in order.
+	Steps []Step `json:"steps"`
+
+	// NamespaceID is the named network namespace to enter, as created by
+	// `ip netns add`. It is resolved under /var/run/netns and /run/netns,
+	// matching iproute2's `ip netns exec` lookup.
+	NamespaceID string `json:"namespaceID"`
+
+	// FirecrackerPath is the firecracker binary to exec.
+	FirecrackerPath string `json:"firecrackerPath"`
+
+	// FirecrackerSocket is the API socket path passed as --api-sock.
+	FirecrackerSocket string `json:"firecrackerSocket"`
+}
diff --git a/packages/orchestrator/internal/sandbox/fc/launchplan/plan_test.go b/packages/orchestrator/internal/sandbox/fc/launchplan/plan_test.go
new file mode 100644
index 0000000..9f58163
--- /dev/null
+++ b/packages/orchestrator/internal/sandbox/fc/launchplan/plan_test.go
@@ -0,0 +1,48 @@
+package launchplan
+
+import (
+	"encoding/json"
+	"testing"
+)
+
+// TestPlanJSONRoundTrip ensures the plan survives the JSON encode/argv/decode
+// round trip that NewProcess -> fc-launch relies on.
+func TestPlanJSONRoundTrip(t *testing.T) {
+	t.Parallel()
+
+	in := Plan{
+		Steps: []Step{
+			{Op: OpTmpfs, Path: "/fc-vm"},
+			{Op: OpSymlink, Path: "/fc-vm/rootfs.ext4", Src: "/orchestrator/sandbox/rootfs.link"},
+			{Op: OpMkdir, Path: "/fc-vm/6.1.0"},
+			{Op: OpSymlink, Path: "/fc-vm/6.1.0/vmlinux.bin", Src: "/fc-kernels/6.1.0/vmlinux.bin"},
+		},
+		NamespaceID:       "ns-7",
+		FirecrackerPath:   "/fc-versions/1.4.0/firecracker",
+		FirecrackerSocket: "/orchestrator/sandbox/fc.sock",
+	}
+
+	encoded, err := json.Marshal(in)
+	if err != nil {
+		t.Fatalf("marshal: %v", err)
+	}
+
+	var out Plan
+	if err := json.Unmarshal(encoded, &out); err != nil {
+		t.Fatalf("unmarshal: %v", err)
+	}
+
+	if out.NamespaceID != in.NamespaceID ||
+		out.FirecrackerPath != in.FirecrackerPath ||
+		out.FirecrackerSocket != in.FirecrackerSocket {
+		t.Fatalf("scalar fields changed: %+v", out)
+	}
+	if len(out.Steps) != len(in.Steps) {
+		t.Fatalf("step count changed: got %d want %d", len(out.Steps), len(in.Steps))
+	}
+	for i := range in.Steps {
+		if out.Steps[i] != in.Steps[i] {
+			t.Fatalf("step %d changed: got %+v want %+v", i, out.Steps[i], in.Steps[i])
+		}
+	}
+}
diff --git a/packages/orchestrator/internal/sandbox/fc/launchplan/run_linux.go b/packages/orchestrator/internal/sandbox/fc/launchplan/run_linux.go
new file mode 100644
index 0000000..8ea37c6
--- /dev/null
+++ b/packages/orchestrator/internal/sandbox/fc/launchplan/run_linux.go
@@ -0,0 +1,135 @@
+//go:build linux
+
+package launchplan
+
+import (
+	"fmt"
+	"os"
+	"path/filepath"
+	"runtime"
+
+	"golang.org/x/sys/unix"
+)
+
+// netnsSearchDirs mirrors iproute2's lookup order for `ip netns exec NAME`.
+var netnsSearchDirs = []string{"/var/run/netns", "/run/netns"}
+
+// Run performs the plan and, on success, never returns: it execs firecracker,
+// replacing the current process image.
+//
+// It must be called from a process that was started in a fresh mount namespace
+// (CLONE_NEWNS); the orchestrator arranges that by spawning this helper
+// through `unshare --mount --propagation unchanged` (see the launch branch in
+// fc/process.go for why the namespace is created in the child and not in the
+// orchestrator's own clone(2) via SysProcAttr.Cloneflags). The wrapper's
+// --propagation unchanged suppresses unshare(1)'s default recursive
+// MS_PRIVATE remount of "/" — the same O(host-mounts) walk Go's Unshareflags
+// path would inject — so cutting mount propagation back to the host is our
+// job, done non-recursively below.
+func Run(plan Plan) error {
+	// The fresh mount namespace still shares mount propagation with the host
+	// (on systemd hosts every mount is shared), so the per-sandbox tmpfs
+	// mounted below would otherwise propagate back to the host mount
+	// namespace. The classic fix is `mount --make-rprivate /` (MS_REC), which
+	// walks the entire host mount tree on every launch and serializes under
+	// the mount namespace lock when many sandboxes resume at once — the very
+	// walk `--propagation unchanged` just avoided. Instead, mark private exactly
+	// the mounts that will receive a tmpfs: O(path depth) syscalls, and
+	// unrelated mounts keep their propagation.
+	for _, s := range plan.Steps {
+		if s.Op != OpTmpfs {
+			continue
+		}
+		if err := makeContainingMountPrivate(s.Path); err != nil {
+			return err
+		}
+	}
+
+	for _, s := range plan.Steps {
+		if err := runStep(s); err != nil {
+			return fmt.Errorf("step %s %q: %w", s.Op, s.Path, err)
+		}
+	}
+
+	// Enter the sandbox network namespace, then exec firecracker in place.
+	// setns(CLONE_NEWNET) only changes the calling OS thread's network
+	// namespace, so we pin the goroutine to its thread and exec from the same
+	// thread; execve collapses the process onto that thread, so firecracker
+	// inherits the sandbox network namespace. This is what `ip netns exec` does.
+	runtime.LockOSThread()
+
+	if err := enterNetns(plan.NamespaceID); err != nil {
+		return err
+	}
+
+	argv := []string{plan.FirecrackerPath, "--api-sock", plan.FirecrackerSocket}
+	if err := unix.Exec(plan.FirecrackerPath, argv, os.Environ()); err != nil {
+		return fmt.Errorf("exec firecracker %q: %w", plan.FirecrackerPath, err)
+	}
+
+	return nil // unreachable: unix.Exec replaced the process image
+}
+
+// makeContainingMountPrivate marks the mount containing path as MS_PRIVATE
+// (non-recursive) so that mounts later placed at path do not propagate to
+// peer namespaces. It walks up from path until it hits a mount point:
+// MS_PRIVATE on a non-mount-point fails with EINVAL, and components that do
+// not exist yet (created later by the tmpfs step) fail with ENOENT — both
+// mean "try the parent". "/" is always a mount point, so the walk terminates.
+func makeContainingMountPrivate(path string) error {
+	dir := filepath.Clean(path)
+	for {
+		err := unix.Mount("", dir, "", unix.MS_PRIVATE, "")
+		switch {
+		case err == nil:
+			return nil
+		case err != unix.EINVAL && err != unix.ENOENT:
+			return fmt.Errorf("make mount of %q private: %w", path, err)
+		case dir == "/":
+			return fmt.Errorf("make mount of %q private: %w", path, err)
+		}
+
+		dir = filepath.Dir(dir)
+	}
+}
+
+func runStep(s Step) error {
+	switch s.Op {
+	case OpMkdir:
+		return os.MkdirAll(s.Path, 0o755)
+	case OpTmpfs:
+		// X-mount.mkdir: ensure the mountpoint exists, then mount the tmpfs.
+		if err := os.MkdirAll(s.Path, 0o755); err != nil {
+			return err
+		}
+		return unix.Mount("tmpfs", s.Path, "tmpfs", 0, "")
+	case OpSymlink:
+		return os.Symlink(s.Src, s.Path)
+	default:
+		return fmt.Errorf("unknown op %q", s.Op)
+	}
+}
+
+// enterNetns opens the named network namespace and setns()es the calling thread
+// into it. The caller must already hold runtime.LockOSThread.
+func enterNetns(namespaceID string) error {
+	var lastErr error
+	for _, dir := range netnsSearchDirs {
+		path := dir + "/" + namespaceID
+		fd, err := unix.Open(path, unix.O_RDONLY|unix.O_CLOEXEC, 0)
+		if err != nil {
+			lastErr = err
+			continue
+		}
+
+		err = unix.Setns(fd, unix.CLONE_NEWNET)
+		_ = unix.Close(fd)
+		if err != nil {
+			return fmt.Errorf("setns %q: %w", path, err)
+		}
+
+		return nil
+	}
+
+	return fmt.Errorf("open netns %q: %w", namespaceID, lastErr)
+}
diff --git a/packages/orchestrator/internal/sandbox/fc/mode.go b/packages/orchestrator/internal/sandbox/fc/mode.go
new file mode 100644
index 0000000..97f46d9
--- /dev/null
+++ b/packages/orchestrator/internal/sandbox/fc/mode.go
@@ -0,0 +1,91 @@
+package fc
+
+import (
+	"os"
+	"strings"
+)
+
+// fcMode selects how NewProcess launches firecracker. It is chosen at runtime
+// via the E2B_FC_LAUNCH_MODE environment variable so the three approaches can be
+// A/B/C-compared without rebuilding the orchestrator:
+//
+//	disabled    (default) — original `unshare -m -- bash -c "... ip netns exec <ns> firecracker"`
+//	netns-exec            — same shell pipeline, but the trailing `ip netns exec` is
+//	                        replaced by the fc-netns-exec helper (setns + execve)
+//	launch                — the dedicated shell-free fc-launch helper (mounts + setns +
+//	                        execve in one tiny process, spawned through a minimal
+//	                        `unshare --mount --propagation unchanged` wrapper), plus
+//	                        inotify-based socket wait
+//	launch-c              — like launch, but the helper is a single-threaded C binary
+//	                        (fc-launch-c) that unshares its own mount namespace: no
+//	                        unshare(1) wrapper and no Go runtime startup on the launch
+//	                        path; the plan travels as argv flags (launchplan.Argv)
+//
+// All optimized modes are off by default so a freshly installed RPM behaves
+// exactly like upstream until the operator opts in.
+type fcMode string
+
+const (
+	modeDisabled  fcMode = "disabled"
+	modeNetnsExec fcMode = "netns-exec"
+	modeLaunch    fcMode = "launch"
+	modeLaunchC   fcMode = "launch-c"
+
+	// envLaunchMode is also read, as a raw string, by package socket (which
+	// cannot import this package) to gate the inotify fast-path.
+	envLaunchMode = "E2B_FC_LAUNCH_MODE"
+)
+
+// fcLaunchMode resolves the configured launch mode, defaulting to modeDisabled
+// for an unset or unrecognized value.
+func fcLaunchMode() fcMode {
+	switch fcMode(os.Getenv(envLaunchMode)) {
+	case modeNetnsExec:
+		return modeNetnsExec
+	case modeLaunch:
+		return modeLaunch
+	case modeLaunchC:
+		return modeLaunchC
+	default:
+		return modeDisabled
+	}
+}
+
+// fcNetnsExecHelperPath is the fc-netns-exec binary used in netns-exec mode.
+// Overridable via E2B_FC_NETNS_EXEC_HELPER; defaults to the RPM install path.
+func fcNetnsExecHelperPath() string {
+	if p := os.Getenv("E2B_FC_NETNS_EXEC_HELPER"); p != "" {
+		return p
+	}
+
+	return "/opt/e2b-infra/bin/fc-netns-exec"
+}
+
+// fcLaunchHelperPath is the fc-launch binary used in launch mode. Overridable
+// via E2B_FC_LAUNCH_HELPER; defaults to the RPM install path.
+func fcLaunchHelperPath() string {
+	if p := os.Getenv("E2B_FC_LAUNCH_HELPER"); p != "" {
+		return p
+	}
+
+	return "/opt/e2b-infra/bin/fc-launch"
+}
+
+// fcLaunchCHelperPath is the fc-launch-c binary used in launch-c mode.
+// Overridable via E2B_FC_LAUNCH_C_HELPER; defaults to the RPM install path.
+func fcLaunchCHelperPath() string {
+	if p := os.Getenv("E2B_FC_LAUNCH_C_HELPER"); p != "" {
+		return p
+	}
+
+	return "/opt/e2b-infra/bin/fc-launch-c"
+}
+
+// netnsExecScript rewrites a generated start script's trailing
+// `ip netns exec <ns> ...` into `<helper> <ns> ...` so that netns-exec mode
+// reuses the exact same shell pipeline as the baseline, only swapping the final
+// network-namespace entry step. Everything before it (mounts/symlinks) is
+// unchanged.
+func netnsExecScript(script, namespaceID, helper string) string {
+	return strings.Replace(script, "ip netns exec "+namespaceID, helper+" "+namespaceID, 1)
+}
diff --git a/packages/orchestrator/internal/sandbox/fc/mode_test.go b/packages/orchestrator/internal/sandbox/fc/mode_test.go
