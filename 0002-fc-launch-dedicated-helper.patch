+// LaunchPlanResult bundles a launchplan.Plan with the computed rootfs/kernel
+// paths (the firecracker process still needs these for the subsequent FC API
+// calls).
+type LaunchPlanResult struct {
+	Plan       launchplan.Plan
+	RootfsPath string
+	KernelPath string
+}
+
+// BuildLaunchPlan produces a shell-free, structured description of how to start
+// firecracker. It is the direct-syscall replacement for Build/GenerateScript:
+// the ordered Steps mirror startScriptV1/startScriptV2 exactly, but are executed
+// in-process by the fc-launch helper (see package launchplan) instead of by
+// `unshare -m -- bash -c "<script>"`.
+func (sb *StartScriptBuilder) BuildLaunchPlan(
+	versions Config,
+	files *storage.SandboxFiles,
+	rootfsPaths RootfsPaths,
+	namespaceID string,
+) (*LaunchPlanResult, error) {
+	args := sb.buildArgs(versions, files, rootfsPaths, namespaceID)
+
+	kernelDir := filepath.Join(args.SandboxDir, args.SandboxKernelDir)
+
+	var steps []launchplan.Step
+	if rootfsPaths.TemplateVersion <= 1 {
+		// Mirror startScriptV1: rootfs tmpfs at DeprecatedSandboxRootfsDir,
+		// a separate kernel tmpfs at <SandboxDir>/<SandboxKernelDir>.
+		steps = []launchplan.Step{
+			{Op: launchplan.OpTmpfs, Path: args.DeprecatedSandboxRootfsDir},
+			{Op: launchplan.OpSymlink, Path: filepath.Join(args.DeprecatedSandboxRootfsDir, args.SandboxRootfsFile), Src: args.HostRootfsPath},
+			{Op: launchplan.OpTmpfs, Path: kernelDir},
+			{Op: launchplan.OpSymlink, Path: filepath.Join(kernelDir, args.SandboxKernelFile), Src: args.HostKernelPath},
+		}
+	} else {
+		// Mirror startScriptV2: single tmpfs at SandboxDir, rootfs symlink under
+		// it, kernel dir mkdir'd under it (no separate tmpfs), kernel symlink.
+		steps = []launchplan.Step{
+			{Op: launchplan.OpTmpfs, Path: args.SandboxDir},
+			{Op: launchplan.OpSymlink, Path: filepath.Join(args.SandboxDir, args.SandboxRootfsFile), Src: args.HostRootfsPath},
+			{Op: launchplan.OpMkdir, Path: kernelDir},
+			{Op: launchplan.OpSymlink, Path: filepath.Join(kernelDir, args.SandboxKernelFile), Src: args.HostKernelPath},
+		}
+	}
+
+	return &LaunchPlanResult{
+		Plan: launchplan.Plan{
+			Steps:             steps,
+			NamespaceID:       args.NamespaceID,
+			FirecrackerPath:   args.FirecrackerPath,
+			FirecrackerSocket: args.FirecrackerSocket,
+		},
+		RootfsPath: sb.getRootfsPath(args, rootfsPaths),
+		KernelPath: sb.getKernelPath(args),
