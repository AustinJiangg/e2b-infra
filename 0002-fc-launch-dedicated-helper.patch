+	CGO_ENABLED=0 GOOS=linux go build -o bin/fc-launch ./cmd/fc-launch
+	$(CC) -O2 -Wall -Wextra -o bin/fc-launch-c ./cmd/fc-launch-c/fc_launch.c
 
