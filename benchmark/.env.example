# benchmark 运行所需的环境变量模板。复制为 .env 后填入本机真实值：
#     cp .env.example .env
# 或直接跑 `bash sync-env.sh`（首次会自动从本模板生成 .env，并填入易变的凭据）。
#
# .env 已被 .gitignore 忽略，切勿把真实 token 提交入库（只提交本模板）。
# run_benchmark.py 会自动加载本目录的 .env（E2B SDK 从环境变量读取以下配置）；
# collect_logs.sh 也会从 .env 读取 NOMAD_TOKEN。

# ---- E2B 客户端（run_benchmark.py / SDK 建沙箱用）----
E2B_API_KEY=""              # 团队 API Key；sync-env.sh 从 /root/.e2b/config.json 的 .teamApiKey 同步
E2B_ACCESS_TOKEN=""         # 访问令牌；  sync-env.sh 从 /root/.e2b/config.json 的 .accessToken 同步
E2B_DOMAIN="e2b.app"
E2B_API_URL="http://<server_ip>:3000"   # 换成本机/服务端地址，如 http://61.47.17.182:3000
E2B_HTTP_SSL="false"

# ---- 运维（collect_logs.sh 采集 orchestrator 日志用）----
NOMAD_TOKEN=""              # Nomad ACL token；sync-env.sh 从 ${NOMAD_DATA_DIR:-/data/nomad}/acl.token 同步
# NOMAD_ADDR="http://127.0.0.1:4646"     # 需要指向远端 Nomad server 时再设
